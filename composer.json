{
    "name": "webconsulting/typo3-abilities",
    "type": "typo3-cms-extension",
    "description": "Abilities registry for TYPO3 — one typed, permissioned registry of what the installation can do; MCP tools, CLI commands and REST routes become projections of it.",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "abilities",
        "capability",
        "registry",
        "mcp",
        "agents"
    ],
    "authors": [
        {
            "name": "Kurt Dirnbauer",
            "email": "dirnbauer@webconsulting.at",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "typo3/cms-core": "^14.3",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "hn/typo3-mcp-server": "Registered abilities are projected as MCP tools automatically",
        "webconsulting/typo3-capability-manifest": "Shares the side-effect subsystem vocabulary and policy semantics"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Abilities\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webconsulting\\Abilities\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "sort-packages": true
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "abilities"
        }
    },
    "scripts": {
        "phpstan": "php -d memory_limit=1G vendor/bin/phpstan analyse",
        "test": "phpunit"
    }
}
